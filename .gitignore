# Merged .gitignore for Project Antigravity

# --- General ---
.DS_Store
*.log
*.tmp
*.bak
.history
*.class
*.pyc
*.swp
.atom/
.svn/
.swiftpm/
migrate_working_dir/

# --- Build Folders (Recursive & Specific) ---
**/build/
**/.dart_tool/
**/node_modules/
**/dist/
**/out/
**/.next/
**/.turbo/
.build/
.buildlog/
/build/
/coverage/

# --- Environment & Sensitive ---
.env
.env.*
!.env.example

# --- IDEs ---
.idea/
.vscode/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/

# --- Flutter/Dart ---
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
**/doc/api/
**/ios/Flutter/.last_build_id

# --- Android specifics ---
**/android/.gradle/
**/android/local.properties
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
/android/app/debug
/android/app/profile
/android/app/release

# --- Symbolication & Obfuscation ---
app.*.symbols
app.*.map.json

# --- OS generated files ---
Thumbs.db
ehthumbs.db
Desktop.ini
